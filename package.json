{
  "name": "thai-cut-browser",
  "description": "A frontend-optimized thai word breaker fork from wordcut with TypeScript support.",
  "version": "1.0.0",
  "homepage": "https://github.com/kitaclang/thai-cut-browser",
  "author": {
    "name": "KC",
    "email": "kitaclang@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kitaclang/thai-cut-browser.git"
  },
  "bugs": {
    "url": "https://github.com/kitaclang/thai-cut-browser/issues/"
  },
  "licenses": [
    {
      "type": "LGPL",
      "url": "http://www.gnu.org/licenses/lgpl.html"
    }
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/*.js",
    "lib/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || >=24.0.0"
  },
  "keywords": [
